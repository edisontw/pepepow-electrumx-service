# Production must use HTTPS. Put TLS configuration in the real server block.
limit_req_zone $binary_remote_addr zone=pepew_api:10m rate=5r/s;
limit_req_zone $binary_remote_addr zone=pepew_heavy:10m rate=3r/s;

server {
    server_name light.pepepow.net;

    limit_req_status 429;

    # Access and Error logs. Ensure logrotate is configured for these files
    # (e.g. in /etc/logrotate.d/pepew-light) to prevent disk space exhaustion.
    access_log /var/log/nginx/pepew-light.access.log;
    error_log /var/log/nginx/pepew-light.error.log;

    # Security headers
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;

    # Bypass rate limits for health checks
    location = /api/health {
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_send_timeout 15s;
        proxy_read_timeout 15s;
    }

    # API Status check using general zone
    location = /api/status {
        limit_req zone=pepew_api burst=20 nodelay;
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_send_timeout 15s;
        proxy_read_timeout 15s;
    }

    # Heavy query routes (address, history, tx, utxo, payment/check)
    location ~ ^/api/(?:address|tx|payment|wallet)/ {
        limit_req zone=pepew_heavy burst=15 nodelay;
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_send_timeout 15s;
        proxy_read_timeout 15s;
    }

    location /api/ {
        limit_req zone=pepew_api burst=20 nodelay;
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_send_timeout 15s;
        proxy_read_timeout 15s;
    }

    location = /favicon.ico {
        alias /var/www/pepew-light/favicon.ico;
        access_log off;
        expires 30d;
    }

    location = /favicon.svg {
        alias /var/www/pepew-light/favicon.svg;
        access_log off;
        expires 30d;
    }

    location = /apple-touch-icon.png {
        alias /var/www/pepew-light/apple-touch-icon.png;
        access_log off;
        expires 30d;
    }

    location = /icon-192.png {
        alias /var/www/pepew-light/icon-192.png;
        access_log off;
        expires 30d;
    }

    location = /icon-512.png {
        alias /var/www/pepew-light/icon-512.png;
        access_log off;
        expires 30d;
    }

    location = /site.webmanifest {
        alias /var/www/pepew-light/site.webmanifest;
        access_log off;
        expires 30d;
        default_type application/manifest+json;
    }

    location = /wallet {
        return 301 /wallet/;
    }

    location /wallet/ {
        root /var/www/pepew-light;
        try_files $uri $uri/ /wallet/index.html;
        access_log /var/log/nginx/pepepow-wallet-access.log;

        location ~* \.(?:js|css|png|jpg|jpeg|gif|ico|svg|webp|woff2?)$ {
            expires 7d;
            add_header Cache-Control "public, max-age=604800";
            add_header X-Content-Type-Options "nosniff" always;
            add_header X-Frame-Options "SAMEORIGIN" always;
            add_header Referrer-Policy "strict-origin-when-cross-origin" always;
            add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
        }
    }

    location / {
        proxy_pass http://127.0.0.1:8088;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 5s;
        proxy_send_timeout 15s;
        proxy_read_timeout 15s;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/light.pepepow.net/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/light.pepepow.net/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}


server {
    if ($host = light.pepepow.net) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name light.pepepow.net;
    return 404; # managed by Certbot


}
